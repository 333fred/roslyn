+                        Report(F1(x, y, z));
+                        Report(F1(y, z, x));
+                        Report(F1(z, x, y));
+                        Report(F2(x, y, z));
+                        Report(F2(y, z, x));
+                        Report(F2(z, x, y));
+                        Report(F3(x, y, z));
+                        Report(F3(y, z, x));
+                        Report(F3(z, x, y));
+                    }
